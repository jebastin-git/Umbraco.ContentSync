{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Umbraco": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSNProviderName": "Microsoft.Data.Sqlite"
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "ContentSync-Demo",
        "SanitizeTinyMce": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true
      }
    }
  }
}
